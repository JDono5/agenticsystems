# AI Agent Passive Income System - Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub.

# ─── ETSY ─────────────────────────────────────────────────────────────────────
# Etsy Developer Portal → https://www.etsy.com/developers/your-apps → create app
ETSY_API_KEY=
ETSY_API_SECRET=
# Generated by running the OAuth 2.0 flow against the Etsy API (Day 1 task)
ETSY_ACCESS_TOKEN=
# Your shop's numeric ID — visible in Etsy Seller Dashboard URL
ETSY_SHOP_ID=

# ─── PRINTIFY ─────────────────────────────────────────────────────────────────
# Printify account → My Profile → Connections → API Access
PRINTIFY_API_KEY=
# Printify account → select your connected Etsy shop → the ID in the URL
PRINTIFY_SHOP_ID=

# ─── OPENAI ───────────────────────────────────────────────────────────────────
# OpenAI platform → https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ─── ANTHROPIC ────────────────────────────────────────────────────────────────
# Anthropic console → https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ─── SUPABASE ─────────────────────────────────────────────────────────────────
# Supabase project → Settings → API → Project URL
SUPABASE_URL=
# Supabase project → Settings → API → service_role secret key (NOT the anon key)
# The service_role key bypasses RLS — required for backend agents to read/write tables
SUPABASE_KEY=

# ─── SENDGRID ─────────────────────────────────────────────────────────────────
# SendGrid account → Settings → API Keys → Create API Key (Full Access)
# Sign up free at https://sendgrid.com — 100 emails/day free forever
SENDGRID_API_KEY=
# The email address that will RECEIVE agent alerts and weekly reports
# Must be a real inbox you check — no verification needed on the recipient side
REPORT_EMAIL=

# ─── FIVERR ───────────────────────────────────────────────────────────────────
# Your Fiverr username (used in fulfillment notes only — no API)
FIVERR_USERNAME=
# Email address where Fiverr sends order notifications (usually same as your Fiverr account email)
FIVERR_NOTIFICATION_EMAIL=

# ─── IMAP (for Fiverr order polling) ──────────────────────────────────────────
# For Gmail: imap.gmail.com | For Outlook: outlook.office365.com
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993
# Defaults to REPORT_EMAIL if not set
IMAP_EMAIL=
# Gmail: Account → Security → 2-Step Verification → App Passwords → create one
IMAP_PASSWORD=

# Set to true to skip IMAP and use sample Fiverr data instead
MOCK_FIVERR=false

# ─── GMAIL / IMAP (for Fiverr order + review emails) ─────────────────────────
# The Gmail address Fiverr sends order/review notifications to
FIVERR_NOTIFICATION_EMAIL=your-gmail@gmail.com
# Gmail App Password — Google Account → Security → 2FA → App passwords → Other
# Must be a 16-char app password, NOT your regular Gmail password
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
GMAIL_IMAP_SERVER=imap.gmail.com
GMAIL_IMAP_PORT=993

# ─── SYSTEM CONTROLS ──────────────────────────────────────────────────────────
# Hard monthly API spend cap in USD — agents halt automatically if this is hit
MONTHLY_SPEND_CAP=100
# Set to true for first 2 weeks (pushes listings as drafts, not live)
# Flip to false after you've reviewed output quality
DRAFT_MODE=true
# Set to true to use sample listings instead of live Etsy API
# Flip to false once your Etsy developer app is active
MOCK_ETSY=false
